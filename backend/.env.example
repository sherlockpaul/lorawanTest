# Copy this file to .env and fill in your values

# PostgreSQL
DATABASE_URL=postgresql://chirpstack_app:password@localhost:5432/lorawan_app

# MQTT (ChirpStack broker — same host as this backend)
MQTT_HOST=localhost
MQTT_PORT=1883

# ChirpStack application ID (from ChirpStack web UI → Applications)
CHIRPSTACK_APPLICATION_ID=210d1bdf-0c93-41f7-bdca-80d870712343

# JWT secret — change this to a long random string
SECRET_KEY=change-me-in-production
